---
 setup.py | 1 -
 1 file changed, 1 deletion(-)

diff --git a/setup.py b/setup.py
index b258d46..0900a6d 100644
--- a/setup.py
+++ b/setup.py
@@ -41,7 +41,6 @@ setup(name=PACKAGENAME,
           'gpstime',
           'igwn-auth-utils',
           'igwn-ligolw>=2.0.0',
